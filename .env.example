# ─────────────────────────────────────────────────────────────────────────────
# AI Workflow — Environment Variables Template
#
# Copy this file to .env and fill in the required values:
#
#   cp .env.example .env
#
# Then open .env and set at minimum GITHUB_TOKEN before running `make setup`
# or `opencode`.
#
# NEVER commit your .env file. It is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# GitHub Personal Access Token.
# Used by the github MCP server for repository operations (read branches,
# issues, pull requests, file contents, and commit history).
#
# HOW TO CREATE (do this once — token never expires):
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"  ← use classic, NOT fine-grained
#   3. Name it: AI Workflow
#   4. Expiration: No expiration            ← IMPORTANT: avoids repeated rotation
#   5. Scopes: check "repo" and "read:org"
#   6. Click Generate token, copy it here
#
# Why classic + no expiration?
#   Fine-grained tokens expire by default (max 1 year, GitHub enforces it).
#   Classic tokens can be set to never expire — ideal for a local dev tool.
GITHUB_TOKEN=

# ── OPTIONAL — MCP Servers ────────────────────────────────────────────────────

# Context7 API key — provides up-to-date library documentation inside agent
# context windows. Without this, the context7 MCP server starts but returns
# no results. Get your free key at: https://context7.com
CONTEXT7_API_KEY=

# Brave Search API key — enables web search for agents that need to look up
# current documentation, CVEs, or external references.
# Get your key at: https://api.search.brave.com/app/keys
BRAVE_API_KEY=

# ── OPTIONAL — Deployment ─────────────────────────────────────────────────────

# Vercel API token — used by the deployer agent for deployment operations and
# by the vercel MCP server (disabled by default in opencode.json).
#
# HOW TO CREATE (do this once — set no expiration):
#   1. Go to https://vercel.com/account/tokens
#   2. Name it: AI Workflow
#   3. Expiration: No expiration            ← avoids repeated rotation
#   4. Click Create, copy it here
VERCEL_TOKEN=

# ── CI/CD — GitHub Actions Website Sync ──────────────────────────────────────
#
# WEBSITE_DEPLOY_TOKEN is used by the GitHub Actions workflow
# (.github/workflows/sync-website.yml) to push synced data files to the
# ASE-OS-Website repository on every push to main.
#
# This is a GitHub Personal Access Token — NOT your regular GITHUB_TOKEN.
# It must have write access to the Albadry-Esmat/ASE-OS-Website repo.
#
# HOW TO CREATE (one-time setup):
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Name it: ASE-OS Website Deploy
#   4. Expiration: No expiration
#   5. Scopes: check "repo" (full control of private repositories)
#   6. Click Generate token — copy the value
#
# HOW TO ADD AS A GITHUB SECRET (required for CI to work):
#   1. Go to https://github.com/Albadry-Esmat/AI-Workflow/settings/secrets/actions
#   2. Click "New repository secret"
#   3. Name:  WEBSITE_DEPLOY_TOKEN
#   4. Value: paste the token you generated above
#   5. Click "Add secret"
#
# The ASE-OS-Website deploy workflow also needs VERCEL_TOKEN added as a secret:
#   1. Go to https://github.com/Albadry-Esmat/ASE-OS-Website/settings/secrets/actions
#   2. Add secret: VERCEL_TOKEN  (same value as above)
#
# Local use only — not read by any script at runtime:
# WEBSITE_DEPLOY_TOKEN=

# ── OPTIONAL — Notifications ─────────────────────────────────────────────────

# Slack integration — currently disabled by default in opencode.json.
# To enable: set these values AND flip "enabled": true for the slack MCP
# server in opencode.json.
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ── LOCAL DEVELOPMENT ─────────────────────────────────────────────────────────

# Absolute path to the ASE-OS Website project on your local machine.
# Used by deployment scripts, doc-maintainer, and any skill that needs to
# reference or operate on the companion website project.
WEBSITE_PATH=/path/to/ASE-OS-Website

# Port for the local website server used by `make website` / rebuild.sh
# Change this if port 3000 is already in use on your machine.
WEBSITE_PORT=3000

# Session file retention window in days for `make sessions` / cleanup-sessions.sh.
# Files older than this value will be flagged (dry-run) or deleted (--delete).
SESSION_RETENTION_DAYS=30
