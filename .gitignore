# macOS
.DS_Store

# Node (website subdirectory dependencies are covered by website/.gitignore)
node_modules/

# Environment / secrets
.env
.env.*

# Editor
.vscode/
.idea/

# Build artefacts
website/.next/
website/out/
website/build/
website/.vercel/

# Vercel project metadata (auto-generated, not needed in repo)
.vercel/

# ─── Graphify generated output (auto-regenerated with `graphify update .`) ───
# Run `graphify update .` after cloning to rebuild the graph for your codebase.
graphify-out/graph.json
graphify-out/graph.html
graphify-out/GRAPH_REPORT.md
graphify-out/manifest.json
graphify-out/.graphify_analysis.json
graphify-out/.graphify_labels.json
graphify-out/.graphify_semantic_marker
graphify-out/cache/
graphify-out/20*/
graphify-out/wiki/

# Logs
*.log

# ─── State backups (created by `aiw backup`) ─────────────────────────────────
backups/

# ─── Work-item runtime content (project-specific, not part of the framework) ─
# The work-items/ directory structure and README are framework; the actual
# tasks/features/bugs you create are yours and should never go to main.
# Use the `develop` branch (or your own fork) to track these.
work-items/*.md
work-items/features/*/
work-items/bugs/*/
work-items/backlog/*.md
work-items/indexes/*.md

# Export artifacts (generated by work-item-exporter)
exports/*.json
exports/*.jsonl
exports/*.md

# ─── Community skill registry cache (populated by skill-registry-client install) ─
# SHA-256 verified skill packages downloaded from the community registry.
# These are transient downloads — never commit them.
.opencode/registry-cache/

# ─── Pipeline spec artifacts (generated by orchestrator after each run) ───────
# Artifacts are gitignored by default — they are runtime outputs, not source.
# To opt-in and track a specific artifact: git add -f artifacts/<filename>
# To always track artifacts: comment out the lines below.
artifacts/*.md
artifacts/*.json
# Always track the directory skeleton (README and .gitkeep are not runtime output)
!artifacts/README.md
!artifacts/.gitkeep

