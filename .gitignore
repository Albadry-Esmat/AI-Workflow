# macOS
.DS_Store

# Node (website subdirectory dependencies are covered by website/.gitignore)
node_modules/

# Environment / secrets
.env
.env.*

# Editor
.vscode/
.idea/

# Build artefacts
website/.next/
website/out/
website/build/
website/.vercel/

# Vercel project metadata (auto-generated, not needed in repo)
.vercel/

# Graphify generated cache (large AST blobs, auto-regenerated)
graphify-out/cache/ast/
graphify-out/20*/

# Logs
*.log

# Work item runtime artifacts (generated by defect-manager, feature-planning, change-request-manager)
# .gitkeep is tracked; actual .md files are runtime outputs not committed to this repo
work-items/*.md

# Export artifacts (generated by work-item-exporter — Jira JSON, JSONL, Markdown, manifests)
# .gitkeep is tracked; actual export files are not committed
exports/*.json
exports/*.jsonl
exports/*.md
