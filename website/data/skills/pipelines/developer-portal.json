{
  "$schema": "../schema/pipeline-schema.json",
  "name": "developer-portal",
  "version": "1.0.1",
  "description": "End-to-end pipeline for developer-facing portals (API docs, SDK explorer, changelog, guides): same foundation as consumer-website with an elevated documentation phase, API contract emphasis in architecture, and SEO tuned for developer search intent",
  "mode": "hybrid",
  "phases": [
    {
      "id": "phase-1-requirements",
      "label": "Requirements",
      "skills": [
        { "name": "requirement-analyzer", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-2-architecture",
      "label": "Architecture",
      "skills": [
        { "name": "architecture-design", "version": "^1.1.0", "max_retries": 2 },
        { "name": "adr-generator",       "version": "^1.0.0", "max_retries": 1, "async": true }
      ]
    },
    {
      "id": "phase-2b-design",
      "label": "UI/UX + Database Design",
      "parallel": true,
      "skills": [
        { "name": "frontend-ux-architect", "version": "^1.0.0", "max_retries": 2 },
        { "name": "database-architect",    "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-2c-design-system",
      "label": "Design System Generation",
      "skills": [
        { "name": "design-system-generator", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-3-graph",
      "label": "Dependency Graph",
      "skills": [
        { "name": "dependency-analyzer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-4-planning",
      "label": "Planning",
      "skills": [
        { "name": "feature-planning", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-5-impact",
      "label": "Impact Analysis",
      "skills": [
        { "name": "change-impact-analyzer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-6-execution",
      "label": "Code Generation",
      "skills": [
        { "name": "code-generator", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7-quality",
      "label": "Quality + Testing",
      "parallel": true,
      "skills": [
        { "name": "clean-code-review", "version": "^1.1.0", "max_retries": 2 },
        { "name": "testing-strategy",  "version": "^1.1.0", "max_retries": 2 },
        { "name": "security-review",   "version": "^1.0.0", "max_retries": 2 },
        { "name": "test-generator",    "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7b-guards",
      "label": "Guard Layer",
      "parallel": true,
      "skills": [
        { "name": "database-guard",         "version": "^1.0.0", "max_retries": 1, "type": "validation_check" },
        { "name": "performance-guard",      "version": "^1.0.0", "max_retries": 1, "type": "validation_check" },
        { "name": "ui-ux-compliance-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-8-repair",
      "label": "Repair (conditional)",
      "condition": "test.failed OR build.broken",
      "skills": [
        { "name": "code-repair", "version": "^1.0.0", "max_retries": 3 }
      ]
    },
    {
      "id": "phase-8b-seo",
      "label": "SEO Optimization",
      "skills": [
        { "name": "seo-optimizer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-8c-audit",
      "label": "Completeness Audit",
      "skills": [
        { "name": "implementation-completeness-auditor", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-8d-release-guard",
      "label": "Release Gate",
      "skills": [
        { "name": "implementation-completeness-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-10-docs",
      "label": "Documentation (synchronous — must complete before deployment)",
      "async": false,
      "skills": [
        { "name": "documentation-generator", "version": "^1.0.0", "max_retries": 2 },
        { "name": "doc-maintainer",          "version": "^1.0.0", "max_retries": 1 }
      ]
    },
    {
      "id": "phase-9-deploy",
      "label": "Deployment",
      "skills": [
        { "name": "deployment-strategy", "version": "^1.1.0", "max_retries": 2 }
      ]
    }
  ],
  "parallel_groups": [
    ["frontend-ux-architect", "database-architect"],
    ["clean-code-review", "testing-strategy", "security-review", "test-generator"],
    ["database-guard", "performance-guard", "ui-ux-compliance-guard"]
  ],
  "gates": [
    {
      "after_phase": "phase-1-requirements",
      "type": "human_approval",
      "label": "Validate developer portal requirements — confirm API surface, SDK targets, and guide scope",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2-architecture",
      "type": "human_approval",
      "label": "Sign off on architecture — confirm API versioning strategy and documentation structure",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2b-design",
      "type": "human_approval",
      "label": "Approve UX architecture (code explorer, search, navigation) and database schema",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2c-design-system",
      "type": "human_approval",
      "label": "Approve design system — confirm developer-appropriate token set and component stubs",
      "timeout": 3600
    },
    {
      "after_phase": "phase-4-planning",
      "type": "human_approval",
      "label": "Approve roadmap before implementation",
      "timeout": 3600
    },
    {
      "after_phase": "phase-5-impact",
      "type": "condition",
      "label": "Block if impact_severity=critical",
      "condition": "change_impact.impact_severity !== 'critical'"
    },
    {
      "after_phase": "phase-7b-guards",
      "type": "condition",
      "label": "Block if any guard verdict is 'block'",
      "condition": "guards.every(g => g.verdict === 'pass')"
    },
    {
      "after_phase": "phase-7-quality",
      "type": "human_approval",
      "label": "Approve security and coverage — important: developer portals expose API keys and auth flows",
      "timeout": 3600
    },
    {
      "after_phase": "phase-8b-seo",
      "type": "condition",
      "label": "Block if SEO compliance coverage is below 100%",
      "condition": "seo.seo_compliance_report.coverage_percentage === 100"
    },
    {
      "after_phase": "phase-8d-release-guard",
      "type": "condition",
      "label": "Block if completeness guard verdict is 'block'",
      "condition": "release_guard.verdict === 'pass'"
    },
    {
      "after_phase": "phase-10-docs",
      "type": "human_approval",
      "label": "Approve documentation — developer portals require complete and accurate docs before deployment",
      "timeout": 7200
    },
    {
      "after_phase": "phase-9-deploy",
      "type": "human_approval",
      "label": "Mandatory deployment approval — non-bypassable",
      "bypass_on_timeout": false,
      "timeout": 0
    }
  ],
  "recovery": {
    "on_critical_failure": "rollback-manager",
    "max_repair_iterations": 3,
    "rollback_scope": "pipeline_stage"
  },
  "async_skills": ["adr-generator"]
}
