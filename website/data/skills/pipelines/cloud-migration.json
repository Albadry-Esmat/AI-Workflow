{
  "$schema": "../schema/pipeline-schema.json",
  "name": "cloud-migration",
  "version": "1.0.0",
  "description": "Cloud migration and modernisation pipeline (v1.0.0): requirements → Well-Architected review → threat model → secrets management → container orchestration (or serverless) → SLO design → security review → load testing → runbooks → deployment. Use for cloud lift-and-shift, re-platforming, or cloud-native rewrites.",
  "mode": "hybrid",
  "phases": [
    {
      "id": "phase-1-requirements",
      "label": "Requirements",
      "skills": [
        { "name": "requirement-analyzer", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-2-architecture",
      "label": "Current + Target Architecture",
      "skills": [
        { "name": "architecture-design", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-3-cloud-review",
      "label": "Well-Architected Review",
      "skills": [
        { "name": "cloud-architecture-reviewer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-4-threat-model",
      "label": "Threat Modeling",
      "skills": [
        { "name": "threat-model-designer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-5-infra-design",
      "label": "Infrastructure Design",
      "parallel": true,
      "skills": [
        { "name": "container-orchestration-architect", "version": "^1.0.0", "max_retries": 2 },
        { "name": "serverless-architect",              "version": "^1.0.0", "max_retries": 2 },
        { "name": "secrets-management-architect",      "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-6-caching",
      "label": "Caching Strategy",
      "skills": [
        { "name": "caching-strategy-designer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7-reliability",
      "label": "SLO Design + Security Review",
      "parallel": true,
      "skills": [
        { "name": "slo-sla-designer", "version": "^1.0.0", "max_retries": 2 },
        { "name": "security-review",  "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-8-devsecops",
      "label": "DevSecOps Pipeline Design",
      "skills": [
        { "name": "devsecops-pipeline-designer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-9-guards",
      "label": "Guard Layer",
      "parallel": true,
      "skills": [
        { "name": "security-guard",    "version": "^1.0.0", "max_retries": 1, "type": "validation_check" },
        { "name": "performance-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-10-load-test",
      "label": "Load Test Design",
      "skills": [
        { "name": "load-test-designer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-11-runbooks",
      "label": "Runbook Generation",
      "skills": [
        { "name": "runbook-generator", "version": "^1.0.0", "max_retries": 1 }
      ]
    },
    {
      "id": "phase-12-ci-pipeline",
      "label": "CI/CD Pipeline Generation",
      "skills": [
        { "name": "ci-pipeline-generator", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-13-deploy",
      "label": "Deployment Strategy",
      "skills": [
        { "name": "deployment-strategy", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-14-docs",
      "label": "Documentation + ADR",
      "async": true,
      "skills": [
        { "name": "documentation-generator", "version": "^1.0.0", "max_retries": 1 },
        { "name": "adr-generator",           "version": "^1.0.0", "max_retries": 1, "async": true },
        { "name": "doc-maintainer",          "version": "^1.0.0", "max_retries": 1 }
      ]
    }
  ],
  "parallel_groups": [
    ["container-orchestration-architect", "serverless-architect", "secrets-management-architect"],
    ["slo-sla-designer", "security-review"],
    ["security-guard", "performance-guard"]
  ],
  "gates": [
    {
      "after_phase": "phase-3-cloud-review",
      "type": "human_approval",
      "label": "Approve Well-Architected findings and remediation priorities before infrastructure design",
      "timeout": 3600
    },
    {
      "after_phase": "phase-4-threat-model",
      "type": "human_approval",
      "label": "Review STRIDE threat catalog and accept risk mitigations before infrastructure design",
      "timeout": 3600
    },
    {
      "after_phase": "phase-5-infra-design",
      "type": "human_approval",
      "label": "Approve infrastructure topology — Kubernetes vs. serverless selection is binding",
      "timeout": 3600
    },
    {
      "after_phase": "phase-9-guards",
      "type": "condition",
      "label": "Block if any guard verdict is 'block'",
      "condition": "guards.every(g => g.verdict === 'pass')"
    },
    {
      "after_phase": "phase-12-ci-pipeline",
      "type": "human_approval",
      "label": "Approve CI/CD pipeline with security gates before enabling deployment",
      "timeout": 3600
    },
    {
      "after_phase": "phase-13-deploy",
      "type": "human_approval",
      "label": "Mandatory deployment approval — non-bypassable",
      "bypass_on_timeout": false,
      "timeout": 0
    }
  ],
  "recovery": {
    "on_critical_failure": "rollback-manager",
    "max_repair_iterations": 3,
    "rollback_scope": "pipeline_stage"
  },
  "async_skills": ["documentation-generator", "adr-generator", "doc-maintainer"]
}
