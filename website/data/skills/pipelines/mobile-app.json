{
  "$schema": "../schema/pipeline-schema.json",
  "name": "mobile-app",
  "version": "1.0.0",
  "description": "End-to-end pipeline for iOS, Android, React Native, Flutter, and MAUI mobile applications: requirements → architecture + mobile domain constraints → DB design → UX design → planning → code generation → mobile safety guard layer → quality + platform testing → completeness audit → deployment + CI scaffold → docs",
  "mode": "hybrid",
  "domain": "mobile",
  "phases": [
    {
      "id": "phase-1-requirements",
      "label": "Requirements",
      "skills": [
        { "name": "requirement-analyzer", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-2-architecture",
      "label": "Architecture (first pass)",
      "skills": [
        { "name": "architecture-design", "version": "^1.3.0", "max_retries": 2 },
        { "name": "adr-generator",       "version": "^1.0.0", "max_retries": 1, "async": true }
      ]
    },
    {
      "id": "phase-2c-domain",
      "label": "Mobile Platform Domain Specialist",
      "note": "Injects technology stack selection, offline strategy, push notification architecture, App Store compliance, mobile security controls, and device matrix into domain_constraints.",
      "skills": [
        { "name": "mobile-platform-specialist", "version": "^1.0.0", "max_retries": 2,
          "config": { "domain_context": { "domain_primary": "mobile" } } }
      ]
    },
    {
      "id": "phase-2d-architecture-refine",
      "label": "Architecture (second pass — mobile-constrained)",
      "skills": [
        { "name": "architecture-design", "version": "^1.3.0", "max_retries": 2,
          "input_overrides": { "domain_constraints": "$phase-2c-domain.domain_constraints" } }
      ]
    },
    {
      "id": "phase-2b-design",
      "label": "UX + Database Design",
      "parallel": true,
      "note": "frontend-ux-architect produces mobile-first responsive design; database-architect produces local + remote schema.",
      "skills": [
        { "name": "frontend-ux-architect", "version": "^1.0.0", "max_retries": 2,
          "config": { "platform_hint": "mobile" } },
        { "name": "database-architect",    "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-3-graph",
      "label": "Dependency Graph",
      "skills": [
        { "name": "dependency-analyzer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-4-planning",
      "label": "Planning",
      "skills": [
        { "name": "feature-planning", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-5-impact",
      "label": "Impact Analysis",
      "skills": [
        { "name": "change-impact-analyzer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-6-execution",
      "label": "Code Generation",
      "skills": [
        { "name": "code-generator", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7-quality",
      "label": "Quality + Testing",
      "parallel": true,
      "skills": [
        { "name": "clean-code-review", "version": "^1.1.0", "max_retries": 2 },
        { "name": "testing-strategy",  "version": "^1.1.0", "max_retries": 2,
          "config": { "domain_hints": ["device_matrix", "xctest", "espresso", "detox", "appium", "accessibility_voiceover_talkback"] } },
        { "name": "security-review",   "version": "^1.0.0", "max_retries": 2 },
        { "name": "test-generator",    "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7b-guards",
      "label": "Guard Layer (Mobile Security)",
      "parallel": true,
      "skills": [
        { "name": "security-guard",    "version": "^1.0.0", "max_retries": 1, "type": "validation_check",
          "config": { "domain": "mobile" },
          "note": "Flags missing certificate pinning and API keys in binary as high-severity blocks." },
        { "name": "database-guard",    "version": "^1.0.0", "max_retries": 1, "type": "validation_check" },
        { "name": "performance-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check",
          "config": { "mobile_budgets": { "cold_start_ms": 2000, "frame_time_ms": 16.67, "memory_mb": 150 } } },
        { "name": "ui-ux-compliance-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-8-repair",
      "label": "Repair (conditional)",
      "condition": "test.failed OR build.broken",
      "skills": [
        { "name": "code-repair", "version": "^1.0.0", "max_retries": 3 }
      ]
    },
    {
      "id": "phase-8b-audit",
      "label": "Completeness Audit",
      "skills": [
        { "name": "implementation-completeness-auditor", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-8c-release-guard",
      "label": "Release Gate",
      "skills": [
        { "name": "implementation-completeness-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-9-deploy",
      "label": "Deployment + CI Scaffold",
      "parallel": true,
      "skills": [
        { "name": "deployment-strategy",   "version": "^1.1.0", "max_retries": 2,
          "config": { "platform_hints": ["app_store", "play_store", "fastlane", "testflight", "firebase_distribution"] } },
        { "name": "ci-pipeline-generator", "version": "^1.0.0", "max_retries": 2,
          "config": { "secret_scan": true, "platform_hints": ["xcode_cloud", "github_actions_ios", "github_actions_android"] } }
      ]
    },
    {
      "id": "phase-10-docs",
      "label": "Documentation",
      "async": true,
      "skills": [
        { "name": "documentation-generator", "version": "^1.0.0", "max_retries": 1 },
        { "name": "doc-maintainer",          "version": "^1.0.0", "max_retries": 1 }
      ]
    }
  ],
  "parallel_groups": [
    ["frontend-ux-architect", "database-architect"],
    ["clean-code-review", "testing-strategy", "security-review", "test-generator"],
    ["security-guard", "database-guard", "performance-guard", "ui-ux-compliance-guard"],
    ["deployment-strategy", "ci-pipeline-generator"]
  ],
  "gates": [
    {
      "after_phase": "phase-1-requirements",
      "type": "human_approval",
      "label": "Validate mobile requirements — confirm target platforms, offline needs, monetization model, and compliance scope",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2-architecture",
      "type": "human_approval",
      "label": "Sign off on initial architecture before mobile domain specialist runs",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2c-domain",
      "type": "human_approval",
      "label": "Approve mobile domain constraints: technology stack, offline strategy, App Store compliance requirements, security controls, device matrix",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2d-architecture-refine",
      "type": "human_approval",
      "label": "Approve mobile-constrained architecture before UX/DB design",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2b-design",
      "type": "human_approval",
      "label": "Approve mobile UX architecture and database schema (local + remote) before planning",
      "timeout": 3600
    },
    {
      "after_phase": "phase-4-planning",
      "type": "human_approval",
      "label": "Approve roadmap and impact surface before mobile implementation",
      "timeout": 3600
    },
    {
      "after_phase": "phase-5-impact",
      "type": "condition",
      "label": "Block if impact_severity=critical",
      "condition": "change_impact.impact_severity !== 'critical'"
    },
    {
      "after_phase": "phase-7b-guards",
      "type": "condition",
      "label": "Block if any guard verdict is 'block' — certificate pinning and API key storage failures are non-bypassable",
      "condition": "guards.every(g => g.verdict === 'pass')"
    },
    {
      "after_phase": "phase-7-quality",
      "type": "human_approval",
      "label": "Approve security posture, device matrix test coverage, and accessibility compliance before audit",
      "timeout": 3600
    },
    {
      "after_phase": "phase-8c-release-guard",
      "type": "condition",
      "label": "Block if completeness guard verdict is 'block'",
      "condition": "release_guard.verdict === 'pass'"
    },
    {
      "after_phase": "phase-9-deploy",
      "type": "human_approval",
      "label": "Mandatory deployment approval — non-bypassable. Confirm App Store / Play Store submission readiness.",
      "bypass_on_timeout": false,
      "timeout": 0
    }
  ],
  "recovery": {
    "on_critical_failure": "rollback-manager",
    "max_repair_iterations": 3,
    "rollback_scope": "pipeline_stage"
  },
  "async_skills": ["documentation-generator", "doc-maintainer", "adr-generator"]
}
