# ─── Site configuration ──────────────────────────────────────────────────────
# Canonical URL of the deployed website (no trailing slash).
# Used in: metadata, sitemap.xml, robots.txt
NEXT_PUBLIC_SITE_URL=https://ase-os.vercel.app

# GitHub repository URL shown in "Star on GitHub" / "View on GitHub" buttons.
NEXT_PUBLIC_REPO_URL=https://github.com/Albadry-Esmat/AI-Workflow

# ─── Data root (optional) ────────────────────────────────────────────────────
# Path to the directory that contains skills/, opencode.json, and docs/.
# Leave unset — the website auto-detects:
#   • If ./data/skills/index.yaml exists  → uses ./data/  (standalone mode)
#   • Otherwise                           → uses ../       (monorepo mode)
# DATA_ROOT=/absolute/path/to/AI-Workflow
