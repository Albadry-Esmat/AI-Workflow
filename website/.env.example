# ─── Site configuration ──────────────────────────────────────────────────────
# Canonical URL of your deployed website (no trailing slash).
# Used in: metadata, sitemap.xml, robots.txt
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Your GitHub repository URL — shown in "Star on GitHub" / "Clone" buttons.
NEXT_PUBLIC_REPO_URL=https://github.com/your-username/ai-workflow

# ─── Data root (optional) ────────────────────────────────────────────────────
# Path to the directory that contains skills/, opencode.json, and docs/.
# Leave unset — the website auto-detects:
#   • If ./data/skills/index.yaml exists  → uses ./data/  (standalone mode)
#   • Otherwise                           → uses ../       (monorepo mode)
# DATA_ROOT=/absolute/path/to/your-project

# ─── Creator identity ────────────────────────────────────────────────────────
# Shown on the About page and in the site footer.
# Set all fields you want visible; leave social links blank to hide that card.
NEXT_PUBLIC_CREATOR_NAME=Your Name
NEXT_PUBLIC_CREATOR_TITLE=Creator of AI Workflow
NEXT_PUBLIC_CREATOR_BIO=Add your bio here — what you build and why.
NEXT_PUBLIC_CREATOR_INITIALS=YN

# Social links — omit or leave blank to hide a platform card on the About page.
NEXT_PUBLIC_CREATOR_GITHUB_HANDLE=@your-github
NEXT_PUBLIC_CREATOR_GITHUB_URL=https://github.com/your-github
NEXT_PUBLIC_CREATOR_TWITTER_HANDLE=@your-twitter
NEXT_PUBLIC_CREATOR_TWITTER_URL=https://x.com/your-twitter
NEXT_PUBLIC_CREATOR_LINKEDIN_HANDLE=Your Name
NEXT_PUBLIC_CREATOR_LINKEDIN_URL=https://linkedin.com/in/your-linkedin
NEXT_PUBLIC_CREATOR_YOUTUBE_HANDLE=@your-youtube
NEXT_PUBLIC_CREATOR_YOUTUBE_URL=https://youtube.com/@your-youtube
NEXT_PUBLIC_CREATOR_INSTAGRAM_HANDLE=@your-instagram
NEXT_PUBLIC_CREATOR_INSTAGRAM_URL=https://instagram.com/your-instagram
NEXT_PUBLIC_CREATOR_WEBSITE_HANDLE=your-website.com
NEXT_PUBLIC_CREATOR_WEBSITE_URL=https://your-website.com
