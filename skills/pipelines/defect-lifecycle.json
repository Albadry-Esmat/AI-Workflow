{
  "$schema": "../schema/pipeline-schema.json",
  "name": "defect-lifecycle",
  "version": "1.1.0",
  "description": "Defect intake → triage (HITL) → investigation → fix → regression test → fix review → validation → closure (HITL). Triggered by defect.created event or direct invocation.",
  "mode": "sequential",
  "phases": [
    {
      "id": "phase-1-intake",
      "label": "Defect Intake",
      "skills": [
        { "name": "defect-manager", "version": "^1.0.0", "max_retries": 1 }
      ]
    },
    {
      "id": "phase-2-investigation",
      "label": "Root Cause Investigation",
      "skills": [
        { "name": "change-impact-analyzer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-3-fix",
      "label": "Fix Implementation",
      "skills": [
        { "name": "code-repair", "version": "^1.0.0", "max_retries": 3 }
      ]
    },
    {
      "id": "phase-4-lifecycle-guard",
      "label": "Lifecycle State Validation",
      "skills": [
        { "name": "work-item-lifecycle-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-5-test",
      "label": "Regression Test Generation",
      "skills": [
        { "name": "test-generator", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-6-review",
      "label": "Fix Review",
      "skills": [
        { "name": "clean-code-review", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7-validate",
      "label": "Completeness Validation",
      "skills": [
        { "name": "implementation-completeness-auditor", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7b-completeness-guard",
      "label": "Completeness Readiness Gate",
      "skills": [
        { "name": "implementation-completeness-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-7c-closure-write",
      "label": "Closure State Persist",
      "skills": [
        { "name": "state-manager", "version": "^1.1.0", "max_retries": 1 }
      ]
    },
    {
      "id": "phase-8-export",
      "label": "Work Item Export",
      "async": true,
      "skills": [
        { "name": "work-item-exporter", "version": "^1.0.0", "max_retries": 1 }
      ]
    },
    {
      "id": "phase-9-docs",
      "label": "Documentation Sync",
      "async": true,
      "skills": [
        { "name": "doc-maintainer", "version": "^1.0.0", "max_retries": 1 }
      ]
    }
  ],
  "gates": [
    {
      "after_phase": "phase-1-intake",
      "type": "human_approval",
      "label": "Confirm defect triage: priority, severity, and assignment before chain generation",
      "timeout": 3600
    },
    {
      "after_phase": "phase-4-lifecycle-guard",
      "type": "condition",
      "label": "Block if lifecycle guard verdict is 'block'",
      "condition": "lifecycle_guard.verdict !== 'block'"
    },
    {
      "after_phase": "phase-7b-completeness-guard",
      "type": "human_approval",
      "label": "Approve fix before closure — confirm regression tests pass, review is clean, and completeness threshold is met",
      "timeout": 3600
    }
  ],
  "recovery": {
    "on_critical_failure": "rollback-manager",
    "max_repair_iterations": 3,
    "rollback_scope": "pipeline_stage"
  },
  "async_skills": ["work-item-exporter", "doc-maintainer"]
}
