{
  "$schema": "../schema/pipeline-schema.json",
  "name": "architecture-only",
  "version": "1.0.0",
  "description": "Quick architecture review: requirements \u2192 architecture design. Use when you have existing requirements and need an architecture decision only.",
  "mode": "sequential",
  "skills": [
    {
      "name": "requirement-analyzer",
      "version": "^1.1.0",
      "max_retries": 2
    },
    {
      "name": "architecture-design",
      "version": "^1.1.0",
      "max_retries": 2
    }
  ],
  "parallel_groups": [],
  "gates": [
    {
      "after_skill": "architecture-design",
      "type": "human_approval",
      "label": "Sign off on architecture",
      "timeout": 3600
    }
  ],
  "async_skills": [],
  "token_policy": {
    "auto_compress": true,
    "trigger_at_percent": 85,
    "budget_tiers": [
      {
        "name": "standard",
        "ceiling": 16000,
        "cascade_mode": "single_pass"
      },
      {
        "name": "large",
        "ceiling": 32000,
        "cascade_mode": "cascade"
      },
      {
        "name": "xl",
        "ceiling": 48000,
        "cascade_mode": "cascade"
      }
    ]
  }
}
