{
  "$schema": "../schema/pipeline-schema.json",
  "name": "iot-embedded",
  "version": "1.0.0",
  "description": "End-to-end pipeline for embedded systems, IoT platforms, and real-time systems: requirements \u2192 architecture + systems domain constraints (HAL, RTOS, protocol, OTA, safety) \u2192 DB/data design \u2192 planning \u2192 code generation \u2192 hardcoded-credential guard (non-bypassable) \u2192 quality + HIL testing strategy \u2192 completeness audit \u2192 deployment + CI scaffold \u2192 docs",
  "mode": "hybrid",
  "domain": "embedded_iot",
  "phases": [
    {
      "id": "phase-1-requirements",
      "label": "Requirements",
      "skills": [
        {
          "name": "requirement-analyzer",
          "version": "^1.1.0",
          "max_retries": 2
        }
      ]
    },
    {
      "id": "phase-2-architecture",
      "label": "Architecture (first pass)",
      "skills": [
        {
          "name": "architecture-design",
          "version": "^1.3.0",
          "max_retries": 2
        },
        {
          "name": "adr-generator",
          "version": "^1.0.0",
          "max_retries": 1,
          "async": true
        }
      ]
    },
    {
      "id": "phase-2c-domain",
      "label": "Systems Domain Specialist",
      "note": "Injects embedded/IoT architecture pattern (bare-metal, RTOS, IoT edge/cloud), memory budget, communication protocol design, OTA firmware update architecture, and safety standard controls into domain_constraints.",
      "skills": [
        {
          "name": "systems-specialist",
          "version": "^1.0.0",
          "max_retries": 2,
          "config": {
            "domain_context": {
              "domain_primary": "embedded_iot"
            }
          }
        }
      ]
    },
    {
      "id": "phase-2d-architecture-refine",
      "label": "Architecture (second pass \u2014 systems-constrained)",
      "note": "Re-invokes architecture-design with domain_constraints from systems-specialist: HAL design, RTOS task model, memory map, integration protocol selection.",
      "skills": [
        {
          "name": "architecture-design",
          "version": "^1.3.0",
          "max_retries": 2,
          "input_overrides": {
            "domain_constraints": "$phase-2c-domain.domain_constraints"
          }
        }
      ]
    },
    {
      "id": "phase-2b-design",
      "label": "Data Architecture",
      "note": "For cloud-connected IoT: device registry, telemetry schema, time-series storage design. For bare-metal: local data structures only.",
      "skills": [
        {
          "name": "database-architect",
          "version": "^1.1.0",
          "max_retries": 2
        }
      ]
    },
    {
      "id": "phase-3-graph",
      "label": "Dependency Graph",
      "skills": [
        {
          "name": "dependency-analyzer",
          "version": "^1.0.0",
          "max_retries": 2
        }
      ]
    },
    {
      "id": "phase-4-planning",
      "label": "Planning",
      "skills": [
        {
          "name": "feature-planning",
          "version": "^1.1.0",
          "max_retries": 2
        }
      ]
    },
    {
      "id": "phase-5-impact",
      "label": "Impact Analysis",
      "skills": [
        {
          "name": "change-impact-analyzer",
          "version": "^1.0.0",
          "max_retries": 2
        }
      ]
    },
    {
      "id": "phase-6-execution",
      "label": "Code Generation",
      "skills": [
        {
          "name": "code-generator",
          "version": "^1.0.0",
          "max_retries": 2,
          "config": {
            "language_hints": [
              "c",
              "cpp",
              "rust"
            ],
            "coding_standard": "MISRA_C_2012"
          }
        }
      ]
    },
    {
      "id": "phase-7-quality",
      "label": "Quality + Testing",
      "parallel": true,
      "skills": [
        {
          "name": "clean-code-review",
          "version": "^1.1.0",
          "max_retries": 2
        },
        {
          "name": "testing-strategy",
          "version": "^1.1.0",
          "max_retries": 2,
          "config": {
            "domain_hints": [
              "unit_test_hardware_stub",
              "hardware_in_the_loop",
              "wcet_analysis",
              "stack_watermark",
              "static_analysis_misra",
              "ota_rollback_test"
            ]
          }
        },
        {
          "name": "security-review",
          "version": "^1.0.0",
          "max_retries": 2
        },
        {
          "name": "test-generator",
          "version": "^1.0.0",
          "max_retries": 2
        }
      ]
    },
    {
      "id": "phase-7b-guards",
      "label": "Guard Layer (IoT Security \u2014 hardcoded credentials NON-BYPASSABLE)",
      "parallel": true,
      "skills": [
        {
          "name": "security-guard",
          "version": "^1.0.0",
          "max_retries": 1,
          "type": "validation_check",
          "config": {
            "domain": "embedded_iot"
          },
          "note": "Hardcoded credential detection is NON-BYPASSABLE for embedded_iot domain. Unsigned firmware OTA is also a block condition. Code remediation required before pipeline can advance."
        },
        {
          "name": "performance-guard",
          "version": "^1.0.0",
          "max_retries": 1,
          "type": "validation_check",
          "config": {
            "embedded_budgets": {
              "isr_max_ms": 1,
              "wcet_margin_factor": 2.0
            }
          }
        }
      ]
    },
    {
      "id": "phase-8-repair",
      "label": "Repair (conditional)",
      "condition": "test.failed OR build.broken",
      "skills": [
        {
          "name": "code-repair",
          "version": "^1.0.0",
          "max_retries": 3
        }
      ]
    },
    {
      "id": "phase-8b-audit",
      "label": "Completeness Audit",
      "skills": [
        {
          "name": "implementation-completeness-auditor",
          "version": "^1.0.0",
          "max_retries": 2
        }
      ]
    },
    {
      "id": "phase-8c-release-guard",
      "label": "Release Gate",
      "skills": [
        {
          "name": "implementation-completeness-guard",
          "version": "^1.0.0",
          "max_retries": 1,
          "type": "validation_check"
        }
      ]
    },
    {
      "id": "phase-9-deploy",
      "label": "Deployment + CI Scaffold",
      "parallel": true,
      "skills": [
        {
          "name": "deployment-strategy",
          "version": "^1.1.0",
          "max_retries": 2,
          "config": {
            "strategy_hints": [
              "ota_staged_rollout",
              "firmware_signing",
              "fleet_health_monitoring"
            ]
          }
        },
        {
          "name": "ci-pipeline-generator",
          "version": "^1.0.0",
          "max_retries": 2,
          "config": {
            "secret_scan": true,
            "platform_hints": [
              "cmake",
              "makefile",
              "platformio",
              "idf_component",
              "zephyr_west"
            ]
          }
        }
      ]
    },
    {
      "id": "phase-10-docs",
      "label": "Documentation",
      "async": true,
      "skills": [
        {
          "name": "documentation-generator",
          "version": "^1.0.0",
          "max_retries": 1
        },
        {
          "name": "doc-maintainer",
          "version": "^1.0.0",
          "max_retries": 1
        }
      ]
    }
  ],
  "parallel_groups": [
    [
      "clean-code-review",
      "testing-strategy",
      "security-review",
      "test-generator"
    ],
    [
      "security-guard",
      "performance-guard"
    ],
    [
      "deployment-strategy",
      "ci-pipeline-generator"
    ]
  ],
  "gates": [
    {
      "after_phase": "phase-1-requirements",
      "type": "human_approval",
      "label": "Validate IoT/embedded requirements \u2014 confirm system type, real-time class, safety standard, hardware target, and communication protocols before domain specialist runs",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2-architecture",
      "type": "human_approval",
      "label": "Sign off on initial architecture before systems domain specialist runs",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2c-domain",
      "type": "human_approval",
      "label": "Approve systems domain constraints: architecture pattern (bare-metal/RTOS/IoT), memory budget, protocol selection, OTA design, safety standard controls \u2014 these are foundational hardware decisions",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2d-architecture-refine",
      "type": "human_approval",
      "label": "Approve hardware-constrained architecture before data design and planning",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2b-design",
      "type": "human_approval",
      "label": "Approve data architecture (device registry, telemetry schema, local data structures) before planning",
      "timeout": 3600
    },
    {
      "after_phase": "phase-4-planning",
      "type": "human_approval",
      "label": "Approve roadmap and impact surface before embedded system implementation",
      "timeout": 3600
    },
    {
      "after_phase": "phase-5-impact",
      "type": "condition",
      "label": "Block if impact_severity=critical",
      "condition": "change_impact.impact_severity !== 'critical'"
    },
    {
      "after_phase": "phase-7b-guards",
      "type": "condition",
      "label": "Block if any guard verdict is 'block' \u2014 hardcoded credentials and unsigned OTA are NON-BYPASSABLE",
      "condition": "guards.every(g => g.verdict === 'pass')",
      "note": "security-guard.verdict='block' with reason='hardcoded_credentials' cannot be overridden for embedded_iot domain. Code remediation required."
    },
    {
      "after_phase": "phase-7-quality",
      "type": "human_approval",
      "label": "Approve security posture, WCET analysis, HIL test coverage, and safety control verification before audit",
      "timeout": 3600
    },
    {
      "after_phase": "phase-8c-release-guard",
      "type": "condition",
      "label": "Block if completeness guard verdict is 'block'",
      "condition": "release_guard.verdict === 'pass'"
    },
    {
      "after_phase": "phase-9-deploy",
      "type": "human_approval",
      "label": "Mandatory deployment approval \u2014 non-bypassable. Confirm firmware signing, OTA rollback tested, and staged fleet rollout plan approved.",
      "bypass_on_timeout": false,
      "timeout": 0
    }
  ],
  "recovery": {
    "on_critical_failure": "rollback-manager",
    "max_repair_iterations": 3,
    "rollback_scope": "pipeline_stage"
  },
  "async_skills": [
    "documentation-generator",
    "doc-maintainer",
    "adr-generator"
  ],
  "token_policy": {
    "auto_compress": true,
    "trigger_at_percent": 85,
    "budget_tiers": [
      {
        "name": "standard",
        "ceiling": 16000,
        "cascade_mode": "single_pass"
      },
      {
        "name": "large",
        "ceiling": 32000,
        "cascade_mode": "cascade"
      },
      {
        "name": "xl",
        "ceiling": 48000,
        "cascade_mode": "cascade"
      }
    ]
  }
}
