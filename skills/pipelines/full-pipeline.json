{
  "$schema": "../schema/pipeline-schema.json",
  "name": "full-pipeline",
  "version": "3.0.0",
  "description": "Full idea-to-production pipeline (v3.0.0): requirements → architecture + UX/DB design → design system → dependency graph → impact analysis → code generation → guard layer → quality + testing → completeness audit → defect management (conditional) → deployment → export + docs",
  "mode": "hybrid",
  "phases": [
    {
      "id": "phase-1-requirements",
      "label": "Requirements",
      "skills": [
        { "name": "requirement-analyzer", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-2-architecture",
      "label": "Architecture",
      "skills": [
        { "name": "architecture-design", "version": "^1.1.0", "max_retries": 2 },
        { "name": "adr-generator",       "version": "^1.0.0", "max_retries": 1, "async": true }
      ]
    },
    {
      "id": "phase-2b-design",
      "label": "UI/UX + Database Design",
      "parallel": true,
      "skills": [
        { "name": "frontend-ux-architect", "version": "^2.0.0", "max_retries": 2 },
        { "name": "database-architect",    "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-2c-design-system",
      "label": "Design System Generation",
      "skills": [
        { "name": "design-system-generator", "version": "^2.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-3-graph",
      "label": "Dependency Graph",
      "skills": [
        { "name": "dependency-analyzer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-4-planning",
      "label": "Planning",
      "skills": [
        { "name": "feature-planning", "version": "^2.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-5-impact",
      "label": "Impact Analysis",
      "skills": [
        { "name": "change-impact-analyzer", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-6-execution",
      "label": "Code Generation",
      "skills": [
        { "name": "code-generator", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7-quality",
      "label": "Quality + Testing",
      "parallel": true,
      "skills": [
        { "name": "clean-code-review", "version": "^1.1.0", "max_retries": 2 },
        { "name": "testing-strategy",  "version": "^1.1.0", "max_retries": 2 },
        { "name": "security-review",   "version": "^1.0.0", "max_retries": 2 },
        { "name": "test-generator",    "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-7b-guards",
      "label": "Guard Layer",
      "parallel": true,
      "skills": [
        { "name": "database-guard",             "version": "^1.0.0", "max_retries": 1, "type": "validation_check" },
        { "name": "performance-guard",          "version": "^1.0.0", "max_retries": 1, "type": "validation_check" },
        { "name": "ui-ux-compliance-guard",     "version": "^2.0.0", "max_retries": 1, "type": "validation_check" },
        { "name": "security-guard",             "version": "^1.0.0", "max_retries": 1, "type": "validation_check" },
        { "name": "work-item-lifecycle-guard",  "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-8-repair",
      "label": "Repair (conditional)",
      "condition": "test.failed OR build.broken",
      "skills": [
        { "name": "code-repair", "version": "^1.0.0", "max_retries": 3 }
      ]
    },
    {
      "id": "phase-8b-audit",
      "label": "Completeness Audit",
      "skills": [
        { "name": "implementation-completeness-auditor", "version": "^1.0.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-8c-release-guard",
      "label": "Release Gate",
      "skills": [
        { "name": "implementation-completeness-guard", "version": "^1.0.0", "max_retries": 1, "type": "validation_check" }
      ]
    },
    {
      "id": "phase-8d-defect-management",
      "label": "Defect Management (conditional)",
      "condition": "defects_detected === true OR missings_count > 0",
      "skills": [
        { "name": "defect-manager", "version": "^1.0.0", "max_retries": 1 }
      ]
    },
    {
      "id": "phase-9-deploy",
      "label": "Deployment",
      "skills": [
        { "name": "deployment-strategy", "version": "^1.1.0", "max_retries": 2 }
      ]
    },
    {
      "id": "phase-10-docs",
      "label": "Documentation",
      "async": true,
      "skills": [
        { "name": "documentation-generator", "version": "^1.0.0", "max_retries": 1 },
        { "name": "doc-maintainer",          "version": "^1.0.0", "max_retries": 1 }
      ]
    },
    {
      "id": "phase-10b-export",
      "label": "Work Item Export",
      "async": true,
      "skills": [
        { "name": "work-item-exporter", "version": "^1.0.0", "max_retries": 1 }
      ]
    }
  ],
  "parallel_groups": [
    ["frontend-ux-architect", "database-architect"],
    ["clean-code-review", "testing-strategy", "security-review", "test-generator"],
    ["database-guard", "performance-guard", "ui-ux-compliance-guard", "security-guard", "work-item-lifecycle-guard"]
  ],
  "gates": [
    {
      "after_phase": "phase-1-requirements",
      "type": "human_approval",
      "label": "Validate requirements scope with stakeholder",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2-architecture",
      "type": "human_approval",
      "label": "Sign off on architecture before design layer",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2b-design",
      "type": "human_approval",
      "label": "Approve UX architecture and database schema before design system generation",
      "timeout": 3600
    },
    {
      "after_phase": "phase-2c-design-system",
      "type": "human_approval",
      "label": "Approve design system token files and component stubs before planning",
      "timeout": 3600
    },
    {
      "after_phase": "phase-4-planning",
      "type": "human_approval",
      "label": "Approve roadmap and impact surface before implementation",
      "timeout": 3600
    },
    {
      "after_phase": "phase-5-impact",
      "type": "condition",
      "label": "Block if impact_severity=critical",
      "condition": "change_impact.impact_severity !== 'critical'"
    },
    {
      "after_phase": "phase-7b-guards",
      "type": "condition",
      "label": "Block if any guard verdict is 'block'",
      "condition": "guards.every(g => g.verdict === 'pass')"
    },
    {
      "after_phase": "phase-7-quality",
      "type": "human_approval",
      "label": "Approve security posture and coverage before audit",
      "timeout": 3600
    },
    {
      "after_phase": "phase-8c-release-guard",
      "type": "condition",
      "label": "Block if completeness guard verdict is 'block'",
      "condition": "release_guard.verdict === 'pass'"
    },
    {
      "after_phase": "phase-8d-defect-management",
      "type": "human_approval",
      "condition": "defects_detected === true OR missings_count > 0",
      "label": "Defect triage: confirm priority, severity, and assignment before repair chain is generated (conditional — only when defects or missings detected)",
      "timeout": 3600
    },
    {
      "after_phase": "phase-9-deploy",
      "type": "human_approval",
      "label": "Mandatory deployment approval — non-bypassable",
      "bypass_on_timeout": false,
      "timeout": 0
    }
  ],
  "recovery": {
    "on_critical_failure": "rollback-manager",
    "max_repair_iterations": 3,
    "rollback_scope": "pipeline_stage"
  },
  "async_skills": ["documentation-generator", "doc-maintainer", "adr-generator", "work-item-exporter"]
}
