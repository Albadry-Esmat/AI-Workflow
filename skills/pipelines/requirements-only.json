{
  "$schema": "../schema/pipeline-schema.json",
  "name": "requirements-only",
  "description": "Extract, normalize, and validate requirements from raw input. Stops after requirement analysis — use when scoping a feature before committing to design.",
  "mode": "sequential",
  "skills": [
    {
      "name": "requirement-analyzer",
      "version": "^1.1.0",
      "max_retries": 2
    }
  ],
  "parallel_groups": [],
  "gates": [
    {
      "after_skill": "requirement-analyzer",
      "type": "human_approval",
      "label": "Validate requirements scope with stakeholder",
      "timeout": 3600
    }
  ],
  "async_skills": []
}
