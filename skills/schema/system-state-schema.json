{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ase-os/schemas/system-state.json",
  "title": "ASE-OS System State",
  "description": "The authoritative state model for the ASE-OS pipeline. All agents and skills read and write through state-manager using this schema. Only state-manager may write directly; all other skills receive scoped slices.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "pipeline_template",
    "created_at",
    "updated_at",
    "token_budget",
    "project_spec",
    "architecture",
    "dependency_graph",
    "task_graph",
    "code_map",
    "skill_registry",
    "decision_log",
    "documentation_state",
    "test_state",
    "security_state",
    "pipeline_state",
    "dispatch_map",
    "event_log",
    "snapshots",
    "rollback_log",
    "adr_index"
  ],
  "properties": {

    "session_id": {
      "type": "string",
      "description": "Unique identifier for this pipeline session (UUID v4)",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },

    "pipeline_template": {
      "type": "string",
      "description": "Name of the pipeline template driving this session",
      "enum": ["full-pipeline", "requirements-only", "architecture-only", "quick-review", "pre-deploy", "consumer-website", "developer-portal", "admin-panel", "insights-pipeline", "insights-adaptation-pipeline", "defect-lifecycle", "change-request", "gap-to-skill", "api-first", "ai-agent-system", "cloud-migration", "compliance-first", "data-engineering", "iot-embedded", "microservices-platform", "ml-platform", "mobile-app", "saas-platform"]
    },

    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Session creation timestamp (ISO 8601)"
    },

    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last state mutation timestamp (ISO 8601)"
    },

    "token_budget": {
      "type": "object",
      "description": "Current token budget tracking for the active pipeline session",
      "additionalProperties": false,
      "required": ["tier", "max_tokens", "consumed_tokens", "remaining_tokens"],
      "properties": {
        "tier": {
          "type": "string",
          "enum": ["quick", "deep", "partial_pipeline", "full_pipeline"]
        },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "consumed_tokens": { "type": "integer", "minimum": 0 },
        "remaining_tokens": { "type": "integer", "minimum": 0 }
      }
    },

    "project_spec": {
      "type": "object",
      "description": "Structured requirements output from requirement-analyzer",
      "properties": {
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/requirement" }
        },
        "open_questions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "domain": { "type": "string" },
        "last_updated": { "type": "string", "format": "date-time" }
      }
    },

    "architecture": {
      "type": "object",
      "description": "System architecture output from architecture-design",
      "properties": {
        "modules": {
          "type": "array",
          "items": { "$ref": "#/$defs/module" }
        },
        "data_flow": { "type": "array", "items": { "type": "object" } },
        "integration_points": { "type": "array", "items": { "type": "object" } },
        "technical_decisions": { "type": "array", "items": { "type": "object" } },
        "last_updated": { "type": "string", "format": "date-time" }
      }
    },

    "dependency_graph": {
      "type": "object",
      "description": "Directed dependency graph maintained by dependency-analyzer",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "files": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["id"]
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "type": { "type": "string", "enum": ["internal", "cross-module", "external"] },
              "depth": { "type": "integer" }
            },
            "required": ["from", "to", "type"]
          }
        },
        "last_updated": { "type": "string", "format": "date-time" },
        "cycle_report": {
          "type": "object",
          "properties": {
            "cycles": { "type": "array" },
            "severity": { "type": "string", "enum": ["none", "warning", "error"] }
          }
        }
      }
    },

    "task_graph": {
      "type": "object",
      "description": "Feature plan task graph from feature-planning",
      "properties": {
        "tasks": {
          "type": "array",
          "items": { "$ref": "#/$defs/task" }
        },
        "milestones": { "type": "array", "items": { "type": "object" } },
        "current_phase": { "type": "string" },
        "last_updated": { "type": "string", "format": "date-time" }
      }
    },

    "code_map": {
      "type": "object",
      "description": "File tree with module assignments and change history",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "module": { "type": "string" },
          "language": { "type": "string" },
          "content_hash": { "type": "string" },
          "last_modified": { "type": "string", "format": "date-time" },
          "generated_by": { "type": "string" }
        },
        "required": ["module", "content_hash"]
      }
    },

    "skill_registry": {
      "type": "object",
      "description": "Snapshot of available skills and their statuses (read from skills/registry.json)",
      "properties": {
        "version": { "type": "string" },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "status": { "type": "string", "enum": ["active", "deprecated", "retired"] }
            },
            "required": ["name", "version", "status"]
          }
        }
      }
    },

    "decision_log": {
      "type": "object",
      "description": "@deprecated — use adr_index instead. decision_log.adrs is maintained for backward compatibility only. The canonical ADR source is the top-level adr_index array, maintained by adr-generator (SKL-027) and written via state-manager scope: 'adr_index'.",
      "properties": {
        "adrs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "pattern": "^ADR-[0-9]{4}$" },
              "title": { "type": "string" },
              "status": { "type": "string", "enum": ["proposed", "accepted", "deprecated", "superseded"] },
              "path": { "type": "string" },
              "date": { "type": "string", "format": "date" }
            },
            "required": ["id", "title", "status", "path"]
          }
        }
      }
    },

    "documentation_state": {
      "type": "object",
      "description": "Documentation coverage and sync status",
      "properties": {
        "last_sync": { "type": "string", "format": "date-time" },
        "stale_sections": { "type": "array", "items": { "type": "string" } },
        "coverage_percent": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },

    "test_state": {
      "type": "object",
      "description": "Test coverage targets and last run results",
      "properties": {
        "coverage_target": { "type": "number", "minimum": 0, "maximum": 100 },
        "current_coverage": { "type": "number", "minimum": 0, "maximum": 100 },
        "last_run": { "type": "string", "format": "date-time" },
        "failing_tests": { "type": "array", "items": { "type": "string" } },
        "invalidated_tests": { "type": "array", "items": { "type": "string" } }
      }
    },

    "security_state": {
      "type": "object",
      "description": "Security findings and audit status (restricted read: security-review only)",
      "properties": {
        "last_audit": { "type": "string", "format": "date-time" },
        "open_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
              "module": { "type": "string" },
              "status": { "type": "string", "enum": ["open", "remediated", "accepted"] }
            },
            "required": ["id", "severity", "status"]
          }
        },
        "gate_status": { "type": "string", "enum": ["pass", "fail", "pending"] }
      }
    },

    "pipeline_state": {
      "type": "object",
      "description": "Current execution state of the active pipeline",
      "properties": {
        "current_phase": { "type": "string" },
        "active_skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "skill": { "type": "string" },
              "status": { "type": "string", "enum": ["pending", "running", "completed", "failed", "cancelled"] },
              "started_at": { "type": "string", "format": "date-time" }
            },
            "required": ["skill", "status"]
          }
        },
        "completed_phases": { "type": "array", "items": { "type": "string" } },
        "failed_phases": { "type": "array", "items": { "type": "string" } }
      }
    },

    "dispatch_map": {
      "type": "object",
      "description": "Event-to-skill handler dispatch map managed by event-router",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "skill": { "type": "string" },
            "priority": { "type": "integer" },
            "filter": { "type": "object" },
            "async": { "type": "boolean" }
          },
          "required": ["skill", "priority"]
        }
      }
    },

    "event_log": {
      "type": "array",
      "description": "Append-only log of all events processed in this session (id + type + source only — no full payloads)",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "source_skill": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "type", "source_skill", "timestamp"]
      }
    },

    "snapshots": {
      "type": "array",
      "description": "Ordered list of state snapshots taken by state-manager",
      "items": { "$ref": "#/$defs/snapshot" }
    },

    "rollback_log": {
      "type": "array",
      "description": "Log of all rollback operations executed in this session",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "trigger_reason": { "type": "string" },
          "failed_snapshot_id": { "type": "string" },
          "restored_snapshot_id": { "type": "string" },
          "modules_affected": { "type": "array", "items": { "type": "string" } },
          "recovery_time_ms": { "type": "integer" },
          "success": { "type": "boolean" }
        },
        "required": ["timestamp", "trigger_reason", "restored_snapshot_id", "success"]
      }
    },

    "adr_index": {
      "type": "array",
      "description": "Index of all ADRs in the session — mirrors decision_log.adrs but maintained by adr-generator",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "pattern": "^ADR-[0-9]{4}$" },
          "title": { "type": "string" },
          "status": { "type": "string" },
          "path": { "type": "string" },
          "date": { "type": "string", "format": "date" }
        },
        "required": ["id", "title", "status", "path"]
      }
    },

    "work_items": {
      "type": "object",
      "description": "Work Lifecycle Management Layer — in-state compressed index of all tracked work items. Full detail for each item is stored in work-items/{TYPE}-{NNNN}.md (file-based persistence per ADR-0001). Not in required[] — absent for all sessions that predate the Work Lifecycle Layer.",
      "additionalProperties": false,
      "properties": {
        "items": {
          "type": "array",
          "description": "Compressed work item references. Each entry is ~120 bytes; full detail is in the linked .md file.",
          "items": { "$ref": "#/$defs/work_item_ref" }
        },
        "sequences": {
          "type": "object",
          "description": "Last-assigned sequence number per work item type (used for ID assignment).",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "type_counts": {
          "type": "object",
          "description": "Count per work item type for quick summary without iterating items[].",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "last_updated": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the most recent work item write."
        }
      },
      "required": ["items", "sequences", "type_counts", "last_updated"]
    },

    "behavioral_telemetry": {
      "type": "object",
      "description": "Optional behavioral telemetry collected by behavioral-telemetry-collector (SKL-047). Only present when telemetry is enabled and opt_out is false. Not in required[] — absence is valid for all existing sessions.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Whether behavioral telemetry collection is active for this session."
        },
        "opt_out": {
          "type": "boolean",
          "description": "Per-project opt-out flag. When true, no telemetry is collected and this object is not populated."
        },
        "pii_scrubbed": {
          "type": "boolean",
          "description": "Confirms all events in this object have been processed by the PII scrubber before storage."
        },
        "events": {
          "type": "array",
          "description": "Anonymized skill-execution events collected during this session. Each event contains only numeric and enum metadata — no user text, code, or credentials.",
          "items": {
            "type": "object",
            "required": ["event_type", "skill_name", "timestamp", "session_id"],
            "additionalProperties": false,
            "properties": {
              "event_type": {
                "type": "string",
                "enum": ["skill.started", "skill.completed", "skill.failed", "gate.passed", "gate.blocked", "feedback.triggered", "capability_gap"]
              },
              "skill_name":   { "type": "string" },
              "timestamp":    { "type": "string", "format": "date-time" },
              "session_id":   { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$" },
              "duration_ms":  { "type": "integer", "minimum": 0 },
              "outcome":      { "type": "string", "enum": ["success", "failure", "skipped", "blocked"] },
              "hitl_verdict": { "type": ["string", "null"], "enum": ["approved", "rejected", "modified", "timeout", null] },
              "pipeline_phase": { "type": "string" },
              "gap_domain":   { "type": "string", "description": "For capability_gap events only — the classified intent domain (enum-bound, not free text)." },
              "gap_id":       { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$", "description": "For capability_gap events only — UUID of the logged gap." }
            }
          }
        },
        "session_summary": {
          "type": "object",
          "description": "Aggregated insights produced by session-insights (SKL-048) at session end.",
          "additionalProperties": false,
          "properties": {
            "generated_at":          { "type": "string", "format": "date-time" },
            "total_skills_invoked":  { "type": "integer", "minimum": 0 },
            "total_hitl_gates":      { "type": "integer", "minimum": 0 },
            "hitl_approval_rate":    { "type": "number",  "minimum": 0, "maximum": 1 },
            "pipeline_success":      { "type": "boolean" },
            "skill_performance": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["skill_name", "invocation_count", "success_rate"],
                "additionalProperties": false,
                "properties": {
                  "skill_name":        { "type": "string" },
                  "invocation_count":  { "type": "integer", "minimum": 0 },
                  "success_rate":      { "type": "number",  "minimum": 0, "maximum": 1 },
                  "failure_rate":      { "type": "number",  "minimum": 0, "maximum": 1 },
                  "p95_duration_ms":   { "type": "integer", "minimum": 0 },
                  "hitl_rejection_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
                }
              }
            }
          }
        },
        "last_collection_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the most recent telemetry event recorded in this session."
        }
      }
    },

    "gap_context": {
      "type": "object",
      "description": "Active capability gap context written by orchestrator when a routing dead-end is classified as a gap (FEATURE-001). TTL: 3600 s. Cleared on successful gap-to-skill completion or cancellation. Not in required[] — absent for sessions with no routing dead-ends.",
      "additionalProperties": false,
      "required": ["gap_id", "raw_prompt", "detected_domain", "timestamp"],
      "properties": {
        "gap_id":          { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$" },
        "raw_prompt":      { "type": "string", "maxLength": 1000 },
        "detected_domain": { "type": "string" },
        "timestamp":       { "type": "string", "format": "date-time" },
        "expires_at":      { "type": "string", "format": "date-time" }
      }
    },

    "gap_to_skill_active": {
      "type": "boolean",
      "description": "Recursion guard flag set by gap-to-skill-pipeline (SKL-065) on entry, cleared on completion, rejection, or error. Prevents concurrent gap-to-skill executions within the same session (FEATURE-004)."
    },

    "retry_context": {
      "type": "object",
      "description": "Retry execution context written by gap-to-skill-pipeline (SKL-065) after successful skill registration (FEATURE-005). TTL: 3600 s. Cleared after retry is presented or declined.",
      "additionalProperties": false,
      "required": ["retry_id", "gap_id", "raw_prompt", "registered_skill_id", "timestamp"],
      "properties": {
        "retry_id":            { "type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$" },
        "gap_id":              { "type": "string", "format": "uuid" },
        "raw_prompt":          { "type": "string", "maxLength": 1000 },
        "registered_skill_id": { "type": "string", "pattern": "^SKL-\\d{3}$" },
        "timestamp":           { "type": "string", "format": "date-time" },
        "expires_at":          { "type": "string", "format": "date-time" }
      }
    },

    "retry_in_progress": {
      "type": "boolean",
      "description": "Recursion guard flag set by orchestrator during a retry execution (FEATURE-005). Prevents a failed retry from emitting another capability_gap event."
    }
  },

  "$defs": {
    "requirement": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "pattern": "^REQ-[0-9]+$" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "string", "enum": ["must", "should", "could", "wont"] },
        "status": { "type": "string", "enum": ["open", "in_progress", "done", "rejected"] }
      },
      "required": ["id", "title", "acceptance_criteria", "priority", "status"]
    },
    "module": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "public_api": { "type": "array", "items": { "type": "object" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "files": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "public_api", "dependencies"]
    },
    "task": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "module": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "done", "blocked"] },
        "depends_on": { "type": "array", "items": { "type": "string" } },
        "estimated_complexity": { "type": "string", "enum": ["xs", "s", "m", "l", "xl"] }
      },
      "required": ["id", "title", "status"]
    },
    "work_item_ref": {
      "type": "object",
      "description": "Compressed in-state work item reference (~120 bytes). Full detail is in file_path.",
      "additionalProperties": false,
      "required": ["id", "type", "title", "status", "lifecycle_state", "priority", "file_path", "created_at", "updated_at"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(TASK|REVIEW|TEST|VALIDATION|DOC|BUG|FIX|INVESTIGATION|CLOSURE|CR)-[0-9]{4,}$",
          "description": "Unique work item identifier in TYPE-NNNN format."
        },
        "type": {
          "type": "string",
          "enum": ["TASK", "REVIEW", "TEST", "VALIDATION", "DOC", "BUG", "FIX", "INVESTIGATION", "CLOSURE", "CR"],
          "description": "Work item type."
        },
        "title": {
          "type": "string",
          "maxLength": 255,
          "description": "Short descriptive title (Jira summary field limit: 255 chars)."
        },
        "status": {
          "type": "string",
          "enum": ["open", "in_progress", "review", "done", "closed", "cancelled", "blocked"],
          "description": "Coarse lifecycle status for routing and filtering."
        },
        "lifecycle_state": {
          "type": "string",
          "description": "Fine-grained state within status (type-specific). E.g. 'reported', 'triaged', 'fixing' for BUG; 'draft', 'ready', 'in_progress' for TASK."
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "severity": {
          "type": ["string", "null"],
          "enum": ["critical", "high", "medium", "low", "info", null],
          "description": "Defect severity. Null for non-BUG types."
        },
        "parent_id": {
          "type": ["string", "null"],
          "description": "Parent work item ID. Null for top-level items."
        },
        "file_path": {
          "type": "string",
          "pattern": "^work-items/[A-Z]+-[0-9]+\\.md$",
          "description": "Relative path to the full-detail .md file (per ADR-0001 file-based persistence model)."
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "snapshot": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["stable", "failed", "pre_rollback"] },
        "scope": { "type": "string" },
        "keys_included": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "label", "timestamp", "status", "keys_included"]
    }
  }
}
